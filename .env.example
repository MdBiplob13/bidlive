# ---- Database ----
MONGODB_URI=mongodb://127.0.0.1:27017/bidlive

# ---- Auth ----
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
COOKIE_NAME=bidlive_token

# ---- Cloudinary ----
# Unsigned (client-side) uploads only need these two public vars + an unsigned upload preset.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
# The signed (server) SDK is optional — only needed if you switch back to /api/upload.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Socket server ----
SOCKET_PORT=4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
CLIENT_ORIGIN=http://localhost:3000

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development
